# njsscan configuration file
# https://github.com/ajinabraham/njsscan#configure-njsscan
---
- nodejs-extensions:
  - .js
  - .jsx
  - .ts
  - .tsx

  template-extensions:
  - .new
  - .hbs
  - ''

  ignore-filenames:
  - spec.js
  - spec.jsx
  - spec.ts
  - spec.tsx

  ignore-paths:
  - node_modules

  # node_timing_attack flags all === comparisons as potential timing side-channels.
  # This frontend codebase has no secret-comparison code; all flagged sites compare
  # numeric enum values (JSON parser token types) with no network-observable timing.
  ignore-rules:
  - node_timing_attack

  severity-filter:
  - WARNING
  - ERROR
